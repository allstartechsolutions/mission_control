generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  scheduled
  in_progress
  waiting
  failed
  completed
  canceled
}

enum TaskExecutorType {
  human
  hulk
  agent
  automation
}

enum TaskBillingType {
  none
  fixed
  hourly
}

enum TaskRunStatus {
  queued
  running
  succeeded
  failed
}

enum TaskRunTrigger {
  manual
  scheduled
  lifecycle
}

enum TaskEventLevel {
  info
  warning
  error
}

enum BoardScope {
  project
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String       @default("user")
  phone         String?
  mobile        String?
  whatsapp      String?
  status        String       @default("active")
  accounts      Account[]
  sessions      Session[]
  suggestions   Suggestion[]
  createdTasks  Task[]       @relation("TaskCreator")
  assignedTasks Task[]       @relation("TaskAssignee")
  taskRuns      TaskRun[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
}

model Client {
  id                  String           @id @default(cuid())
  companyName         String
  logoPath            String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  zipCode             String?
  country             String?
  phone               String?
  mobile              String?
  whatsapp            String?
  primaryContactName  String?
  primaryContactTitle String?
  primaryContactEmail String?
  primaryContactPhone String?
  status              String           @default("active")
  locations           ClientLocation[]
  employees           ClientEmployee[]
  projects            Project[]
  accounts            ClientAccount[]
  suggestions         Suggestion[]
  tasks               Task[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([companyName])
  @@index([status])
}

model ClientLocation {
  id           String  @id @default(cuid())
  clientId     String
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  country      String?
  phone        String?
  status       String  @default("active")

  client             Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  primaryEmployees   ClientEmployee[]         @relation("PrimaryLocation")
  secondaryEmployees ClientEmployeeLocation[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([clientId])
  @@index([status])
}

model ClientEmployeeLocation {
  employeeId String
  locationId String
  employee   ClientEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location   ClientLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([employeeId, locationId])
  @@index([locationId])
}

model ClientEmployee {
  id                 String                   @id @default(cuid())
  clientId           String
  name               String
  title              String?
  email              String?
  phone              String?
  mobile             String?
  whatsapp           String?
  profileImagePath   String?
  status             String                   @default("active")
  primaryLocationId  String?
  client             Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  primaryLocation    ClientLocation?          @relation("PrimaryLocation", fields: [primaryLocationId], references: [id], onDelete: SetNull)
  secondaryLocations ClientEmployeeLocation[]
  requestedProjects  Project[]                @relation("ProjectRequester")
  requestedTasks     Task[]                   @relation("TaskRequester")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([primaryLocationId])
}


model ClientAccount {
  id                String   @id @default(cuid())
  clientId          String
  name              String
  description       String?
  usernameEncrypted String
  passwordEncrypted String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([name])
}

model Project {
  id             String             @id @default(cuid())
  name           String
  clientId       String
  requesterId    String?
  status         String             @default("planned")
  priority       String             @default("medium")
  description    String?
  estimatedPrice Decimal?           @db.Decimal(12, 2)
  finalPrice     Decimal?           @db.Decimal(12, 2)
  startDate      DateTime?
  dueDate        DateTime?
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requester      ClientEmployee?    @relation("ProjectRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  milestones     ProjectMilestone[]
  tasks          Task[]
  board          Board?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([clientId])
  @@index([requesterId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model ProjectMilestone {
  id             String    @id @default(cuid())
  projectId      String
  title          String
  description    String?
  status         String    @default("planned")
  sortOrder      Int       @default(0)
  dueDate        DateTime?
  estimatedPrice Decimal?  @db.Decimal(12, 2)
  finalPrice     Decimal?  @db.Decimal(12, 2)
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          Task[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([sortOrder])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Suggestion {
  id              String                 @id @default(cuid())
  title           String
  body            String
  category        String?
  area            String?
  impact          String?
  effort          String?
  whyItMatters    String?
  expectedOutcome String?
  linkedProject   String?
  decisionNotes   String?
  status          String                 @default("new")
  suggestedAt     DateTime               @default(now())
  suggestedById   String
  suggestedBy     User                   @relation(fields: [suggestedById], references: [id], onDelete: Restrict)
  clientId        String?
  client          Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  attachments     SuggestionAttachment[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status])
  @@index([suggestedAt])
  @@index([suggestedById])
  @@index([clientId])
}

model SuggestionAttachment {
  id           String     @id @default(cuid())
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  filePath     String
  fileName     String
  storedName   String
  fileSize     Int
  mimeType     String?
  createdAt    DateTime   @default(now())

  @@index([suggestionId])
}

model Task {
  id                  String            @id @default(cuid())
  title               String
  description         String?
  status              TaskStatus        @default(scheduled)
  executorType        TaskExecutorType  @default(human)
  billingType         TaskBillingType   @default(none)
  billable            Boolean           @default(false)
  amount              Decimal?          @db.Decimal(12, 2)
  billedAt            DateTime?
  startDate           DateTime?
  dueDate             DateTime
  createdById         String
  assignedToId        String
  clientId            String?
  projectId           String?
  milestoneId         String?
  requesterEmployeeId String?
  cronExpression      String?
  cronTimezone        String?
  cronEnabled         Boolean           @default(false)
  cronLastRunAt       DateTime?
  cronNextRunAt       DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  createdBy           User              @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo          User              @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Restrict)
  client              Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project             Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestone           ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  requesterEmployee   ClientEmployee?   @relation("TaskRequester", fields: [requesterEmployeeId], references: [id], onDelete: SetNull)
  taskRuns            TaskRun[]
  taskEvents          TaskRunEvent[]
  boardPlacement      TaskBoardPlacement?

  @@index([status])
  @@index([assignedToId])
  @@index([createdById])
  @@index([clientId])
  @@index([projectId])
  @@index([milestoneId])
  @@index([requesterEmployeeId])
  @@index([dueDate])
}

model Board {
  id         String               @id @default(cuid())
  scope      BoardScope           @default(project)
  name       String
  projectId  String               @unique
  project    Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns    BoardColumn[]
  placements TaskBoardPlacement[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([scope])
}

model BoardColumn {
  id         String               @id @default(cuid())
  boardId    String
  key        String
  name       String
  color      String?
  sortOrder  Int
  board      Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  placements TaskBoardPlacement[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([boardId, key])
  @@unique([boardId, sortOrder])
  @@index([boardId])
}

model TaskBoardPlacement {
  id        String      @id @default(cuid())
  taskId     String      @unique
  boardId    String
  columnId   String
  sortOrder  Int         @default(0)
  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column     BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([boardId, columnId, sortOrder])
  @@index([boardId, columnId])
  @@index([columnId, sortOrder])
}

model TaskRun {
  id                String         @id @default(cuid())
  taskId            String
  trigger           TaskRunTrigger
  status            TaskRunStatus  @default(queued)
  dispatchMode      String?
  commandOrPrompt   String?
  summary           String?
  logPath           String?
  initiatedByUserId String?
  startedAt         DateTime?
  finishedAt        DateTime?
  exitCode          Int?
  errorMessage      String?
  errorStack        String?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  task              Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  initiatedByUser   User?          @relation(fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  events            TaskRunEvent[]

  @@index([taskId, createdAt])
  @@index([status, createdAt])
  @@index([initiatedByUserId])
}

model TaskRunEvent {
  id        String         @id @default(cuid())
  taskId    String
  runId     String?
  level     TaskEventLevel @default(info)
  eventType String
  message   String
  details   Json?
  createdAt DateTime       @default(now())
  task      Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  run       TaskRun?       @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([runId, createdAt])
  @@index([eventType, createdAt])
}
