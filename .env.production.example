# Mission Control production environment example
# Copy to /home/jr/MissionControl/.env on the production checkout only.

DATABASE_URL="postgresql://mission_control:replace-with-real-password@localhost:5432/mission_control"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
CRON_SECRET="replace-with-a-strong-secret"
CLIENT_ACCOUNT_CREDENTIALS_KEY="replace-with-a-32-byte-base64-or-64-char-hex-key"
AUTH_URL="http://192.168.20.30:3001"
NEXTAUTH_URL="http://192.168.20.30:3001"
INTERNAL_APP_URL="http://127.0.0.1:3001"
MISSION_CONTROL_ENV="production"
NEXT_PUBLIC_APP_ENV_LABEL=""
NEXT_PUBLIC_APP_ENV_TONE="slate"
ALLOW_DESTRUCTIVE_SEED="false"
