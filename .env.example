# Mission Control environment template
# Copy this file to `.env` and fill in real values for this machine.
# Never commit real secrets or real private connection strings.

# PostgreSQL connection string for the Mission Control app database.
DATABASE_URL="postgresql://mission_control:replace-with-real-password@localhost:5432/mission_control"

# Auth / session secrets. Use long random values in production.
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Secret used by the cron wake endpoint.
CRON_SECRET="replace-with-a-strong-secret"

# 32-byte key for reversible client account credential encryption.
# Generate with: openssl rand -base64 32
CLIENT_ACCOUNT_CREDENTIALS_KEY="replace-with-a-32-byte-base64-or-64-char-hex-key"

# Public URL the browser should stay on after auth and redirects.
AUTH_URL="http://192.168.20.30:3001"
NEXTAUTH_URL="http://192.168.20.30:3001"

# Internal URL used by local cron/scripts to call the app.
INTERNAL_APP_URL="http://127.0.0.1:3001"

# Treat Mission Control as production once real data starts going in.
MISSION_CONTROL_ENV="production"

# Safety switch for destructive seed behavior.
# Keep this false in production. Only set to true if JR explicitly approves.
ALLOW_DESTRUCTIVE_SEED="false"
