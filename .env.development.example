# Mission Control development environment example
# Copy to /home/jr/MissionControl-dev/.env.development.local in the dev checkout.

DATABASE_URL="postgresql://mission_control_dev:replace-with-real-password@localhost:5432/mission_control_dev"
AUTH_SECRET="replace-with-a-dev-secret"
NEXTAUTH_SECRET="replace-with-a-dev-secret"
CRON_SECRET="replace-with-a-dev-cron-secret"
CLIENT_ACCOUNT_CREDENTIALS_KEY="replace-with-a-dev-32-byte-base64-or-64-char-hex-key"
AUTH_URL="http://192.168.20.30:3002"
NEXTAUTH_URL="http://192.168.20.30:3002"
INTERNAL_APP_URL="http://127.0.0.1:3002"
MISSION_CONTROL_ENV="development"
NEXT_PUBLIC_APP_ENV_LABEL="DEV"
NEXT_PUBLIC_APP_ENV_TONE="amber"
ALLOW_DESTRUCTIVE_SEED="false"
